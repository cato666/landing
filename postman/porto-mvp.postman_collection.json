    {
      "name": "Landings",
      "item": [
        {
          "name": "Render Landing",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);",
                  "if (json.renderId) pm.collectionVariables.set('renderId', json.renderId);",
                  "if (json.publicUrl) pm.collectionVariables.set('publicUrl', json.publicUrl);"
                ]
              }
            }
          ],
