<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{default presentation.brandTag "Porto Seguro · Painel da Apólice"}}</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root{
      --bg:#f4f7fc;
      --bg-2:#eaf0fb;
      --card:#ffffff;
      --text:#17304d;
      --muted:#687a96;
      --primary:#1e5eff;
      --primary-2:#4f8bff;
      --primary-soft:#edf3ff;
      --success:#0f9f61;
      --border:#d8e2f0;
      --shadow:0 16px 40px rgba(23,48,77,.10);
      --radius:22px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Inter,Segoe UI,Arial,sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, rgba(79,139,255,.16), transparent 24%),
        linear-gradient(180deg, var(--bg-2) 0%, var(--bg) 220px);
    }

    .shell{max-width:1360px;margin:0 auto;padding:22px}

    .topbar{
      position:sticky;top:14px;z-index:1000;
      display:flex;align-items:center;justify-content:space-between;gap:16px;
      background:rgba(255,255,255,.82);
      border:1px solid rgba(216,226,240,.9);
      backdrop-filter:blur(14px);
      border-radius:999px;
      padding:14px 18px;
      box-shadow:var(--shadow);
    }
    .brand{display:flex;align-items:center;gap:12px;min-width:0}
    .brand-mark{width:42px;height:42px;border-radius:14px;background:linear-gradient(180deg,var(--primary-2),var(--primary));box-shadow:0 10px 24px rgba(30,94,255,.22)}
    .brand-copy{min-width:0}
    .brand-copy strong{display:block;font-size:18px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .brand-copy span{display:block;margin-top:4px;color:var(--muted);font-size:12px;font-weight:700}
    .nav{display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end}
    .nav a{
      text-decoration:none;color:var(--text);font-size:14px;font-weight:800;
      padding:10px 14px;border-radius:999px;border:1px solid var(--border);background:#fff;
      transition:.2s ease;
    }
    .nav a:hover,.nav a.active{background:var(--primary-soft);border-color:#bfd2fb;color:var(--primary)}

    .layout{
      margin-top:18px;
      display:grid;
      grid-template-columns:360px minmax(0,1fr);
      gap:20px;
      align-items:start;
    }

    .sidebar{
      position:sticky;top:92px;
      display:grid;gap:18px;
    }

    .hero-card,
    .info-card,
    .section-card,
    .kpi,
    .timeline-card,
    .contact-card{
      background:var(--card);
      border:1px solid var(--border);
      box-shadow:var(--shadow);
      border-radius:var(--radius);
    }

    .hero-card{
      overflow:hidden;
      background:linear-gradient(145deg,#0f2142 0%, #1657df 66%, #73a7ff 120%);
      color:#fff;
    }
    .hero-top{padding:24px 24px 16px}
    .hero-badge{
      display:inline-flex;align-items:center;gap:8px;
      padding:8px 12px;border-radius:999px;
      background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);
      font-size:12px;font-weight:800;letter-spacing:.02em;
    }
    .hero-card h1{margin:14px 0 10px;font-size:28px;line-height:1.05}
    .hero-card p{margin:0;color:rgba(255,255,255,.86);line-height:1.6}
    .hero-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 24px 24px}
    .hero-stat{
      background:rgba(255,255,255,.12);
      border:1px solid rgba(255,255,255,.14);
      border-radius:18px;padding:14px;
    }
    .hero-stat label{display:block;font-size:11px;opacity:.78;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px}
    .hero-stat strong{font-size:15px;line-height:1.35}

    .vehicle-shot{padding:16px}
    .vehicle-shot img{width:100%;height:220px;object-fit:cover;border-radius:18px;display:block;background:#dbe8ff}
    .vehicle-shot h3{margin:14px 0 4px;font-size:20px}
    .vehicle-shot p{margin:0;color:#dbe8ff;font-size:14px}

    .info-card,.contact-card,.timeline-card{padding:20px}
    .info-card h2,.section-card h2,.contact-card h2,.timeline-card h2{margin:0 0 14px;font-size:20px}

    .quick-list{display:grid;gap:12px}
    .quick-item{padding:14px;border-radius:16px;background:#f8fbff;border:1px solid #e5eefb}
    .quick-item label{display:block;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;font-weight:800}
    .quick-item strong,.quick-item span{font-size:15px;line-height:1.45}

    .timeline{display:grid;gap:14px}
    .timeline-step{display:grid;grid-template-columns:42px 1fr;gap:12px;align-items:start}
    .timeline-icon{
      width:42px;height:42px;border-radius:14px;background:var(--primary-soft);color:var(--primary);
      display:flex;align-items:center;justify-content:center;font-weight:900;border:1px solid #cfe0ff;
    }
    .timeline-copy strong{display:block;margin-bottom:4px}
    .timeline-copy span{display:block;color:var(--muted);line-height:1.55;font-size:14px}

    .content{display:grid;gap:20px}

    .summary-banner{
      background:linear-gradient(135deg,#ffffff 0%, #f6f9ff 100%);
      border:1px solid var(--border);border-radius:28px;box-shadow:var(--shadow);
      padding:24px;display:grid;grid-template-columns:1.15fr .85fr;gap:18px;align-items:center;
    }
    .summary-banner h2{margin:0 0 10px;font-size:30px;line-height:1.05}
    .summary-banner p{margin:0;color:var(--muted);line-height:1.7;max-width:760px}
    .summary-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:18px}
    .chip{
      display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:999px;
      background:var(--primary-soft);border:1px solid #cfe0ff;color:var(--primary);font-weight:800;font-size:13px;
    }
    .banner-right{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .kpi{padding:18px}
    .kpi span{display:block;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em;font-weight:800;margin-bottom:8px}
    .kpi strong{display:block;font-size:22px;line-height:1.1}
    .kpi small{display:block;margin-top:8px;color:var(--muted);line-height:1.5}

    .section-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
    .section-card{padding:22px}
    .section-head{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:16px}
    .section-head p{margin:6px 0 0;color:var(--muted);line-height:1.6}

    .pill-list{display:flex;flex-wrap:wrap;gap:10px}
    .pill{padding:10px 14px;border-radius:999px;background:var(--primary-soft);border:1px solid #cfe0ff;color:var(--primary);font-weight:700;font-size:14px}

    .table-wrap{overflow:auto}
    table{width:100%;border-collapse:collapse;font-size:14px}
    th,td{text-align:left;padding:12px 10px;border-bottom:1px solid var(--border)}
    th{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.05em}

    .coverage-list{display:grid;gap:12px}
    .coverage-item{padding:16px;border-radius:16px;background:#f8fbff;border:1px solid #e5eefb}
    .coverage-item strong{display:flex;justify-content:space-between;gap:12px;font-size:15px;margin-bottom:8px}
    .coverage-item p{margin:0;color:var(--muted);line-height:1.6;font-size:14px}
    .money{color:var(--success)}

    .chart-wrap{display:grid;grid-template-columns:300px 1fr;gap:18px;align-items:center}
    .chart-box{position:relative;height:280px}
    .legend{display:grid;gap:10px}
    .legend-item{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 14px;border-radius:14px;background:#f8fbff;border:1px solid #e5eefb}
    .legend-left{display:flex;align-items:center;gap:10px;min-width:0}
    .legend-dot{width:12px;height:12px;border-radius:999px;flex:0 0 auto}
    .legend-label{font-weight:700;font-size:14px}
    .legend-value{color:var(--muted);font-size:13px;font-weight:700}

    .address-card{padding:18px;border-radius:18px;background:#f8fbff;border:1px solid #e5eefb;margin-bottom:14px}
    .address-card label{display:block;color:var(--muted);font-size:11px;text-transform:uppercase;letter-spacing:.06em;font-weight:800;margin-bottom:6px}
    .address-card strong{font-size:15px;line-height:1.55}
    .map{width:100%;height:300px;border:0;border-radius:18px;background:#e7eefc}

    @media (max-width:1180px){
      .layout{grid-template-columns:1fr}
      .sidebar{position:static}
      .summary-banner,.section-grid,.chart-wrap{grid-template-columns:1fr}
      .chart-box{height:320px}
    }
    @media (max-width:760px){
      .shell{padding:14px}
      .topbar{border-radius:28px;padding:14px}
      .nav{display:none}
      .hero-stats,.banner-right,.section-grid{grid-template-columns:1fr}
      .summary-banner h2{font-size:26px}
      .hero-card h1{font-size:24px}
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="brand">
        <div class="brand-mark"></div>
        <div class="brand-copy">
          <strong>{{default branding.empresa "Porto Seguro"}}</strong>
          <span>{{default presentation.navSubtitle "Template executivo · painel inteligente"}}</span>
        </div>
      </div>
      <nav class="nav">
        <a href="#visao-geral">Visão geral</a>
        <a href="#coberturas">Coberturas</a>
        <a href="#pagamento">Pagamento</a>
        <a href="#atendimento">Atendimento</a>
      </nav>
    </header>

    <div class="layout">
      <aside class="sidebar">
        <section class="hero-card" id="visao-geral">
          <div class="hero-top">
            <div class="hero-badge">{{default presentation.brandTag "Apólice digital executiva"}}</div>
            <h1>{{default presentation.heroTitle (concat "Olá, " cliente.nome)}}</h1>
            <p>{{default presentation.heroDescription "Uma leitura mais executiva da apólice, com resumo financeiro, composição de coberturas e acesso rápido às informações-chave."}}</p>
          </div>
          <div class="vehicle-shot">
            <img src="{{vehiculo.fotoUrl}}" alt="Foto do veículo" />
            <h3>{{default presentation.vehicleTitle vehiculo.modelo}}</h3>
            <p>{{presentation.vehicleSubtitle}}</p>
          </div>
          <div class="hero-stats">
            <div class="hero-stat"><label>Apólice</label><strong>{{default poliza.numero "-"}}</strong></div>
            <div class="hero-stat"><label>Vigência</label><strong>{{presentation.vigenciaTexto}}</strong></div>
            <div class="hero-stat"><label>Prêmio</label><strong>{{formatCurrency poliza.primaTotal poliza.moneda}}</strong></div>
            <div class="hero-stat"><label>Franquia</label><strong>{{formatCurrency poliza.franquia poliza.moneda}}</strong></div>
          </div>
        </section>

        <section class="info-card">
          <h2>Segurado</h2>
          <div class="quick-list">
            <div class="quick-item"><label>Nome</label><strong>{{cliente.nome}}</strong></div>
            <div class="quick-item"><label>CPF / Documento</label><span>{{cliente.documento}}</span></div>
            <div class="quick-item"><label>Telefone</label><span>{{cliente.telefone}}</span></div>
            <div class="quick-item"><label>E-mail</label><span>{{cliente.email}}</span></div>
          </div>
        </section>

        <section class="timeline-card">
          <h2>Leitura rápida</h2>
          <div class="timeline">
            <div class="timeline-step">
              <div class="timeline-icon">1</div>
              <div class="timeline-copy">
                <strong>Status da apólice</strong>
                <span>{{default poliza.estado "Vigente"}} com resumo financeiro e vigência consolidada.</span>
              </div>
            </div>
            <div class="timeline-step">
              <div class="timeline-icon">2</div>
              <div class="timeline-copy">
                <strong>Composição de proteção</strong>
                <span>As coberturas aparecem em formato executivo para facilitar a compreensão.</span>
              </div>
            </div>
            <div class="timeline-step">
              <div class="timeline-icon">3</div>
              <div class="timeline-copy">
                <strong>Ação imediata</strong>
                <span>Canais, corretora e endereço ficam disponíveis em uma única visão.</span>
              </div>
            </div>
          </div>
        </section>
      </aside>

      <main class="content">
        <section class="summary-banner">
          <div>
            <h2>Mesmo dado, nova experiência visual</h2>
            <p>
              Esta versão mostra como o mesmo modelo canônico pode ser apresentado em um layout mais executivo,
              com foco em leitura rápida, visualização analítica e percepção de valor digital.
            </p>
            <div class="summary-actions">
              <span class="chip">Template alternativo</span>
              <span class="chip">Visão executiva</span>
              <span class="chip">Mesmo payload</span>
            </div>
          </div>
          <div class="banner-right">
            <article class="kpi"><span>Status</span><strong>{{default poliza.estado "Vigente"}}</strong><small>Visão resumida do estado atual da apólice.</small></article>
            <article class="kpi"><span>Forma de pagamento</span><strong>{{pagos.forma}}</strong><small>Modelo de cobrança apresentado de forma destacada.</small></article>
            <article class="kpi"><span>Benefícios</span><strong>{{default presentation.beneficiosCount "Lista dinâmica"}}</strong><small>Quantidade de assistências e conveniências incluídas.</small></article>
            <article class="kpi"><span>Coberturas</span><strong>{{default presentation.coberturasCount "Mapa visual"}}</strong><small>Proteções consolidadas em leitura visual e analítica.</small></article>
          </div>
        </section>

        <div class="section-grid">
          <section class="section-card" id="coberturas">
            <div class="section-head">
              <div>
                <h2>Benefícios e assistências</h2>
                <p>Os itens são apresentados em formato de chips para leitura rápida.</p>
              </div>
            </div>
            <div class="pill-list">
              {{#each beneficios}}
                <div class="pill">{{this.titulo}}</div>
              {{/each}}
            </div>
          </section>

          <section class="section-card" id="pagamento">
            <div class="section-head">
              <div>
                <h2>Agenda de pagamento</h2>
                <p>Parcelas organizadas em tabela para acompanhamento simples.</p>
              </div>
            </div>
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Parcela</th>
                    <th>Vencimento</th>
                    <th>Valor</th>
                  </tr>
                </thead>
                <tbody>
                  {{#each pagos.cuotas}}
                    <tr>
                      <td>{{this.numero}}</td>
                      <td>{{formatDateBR this.vencimiento}}</td>
                      <td>{{formatCurrency this.valor ../poliza.moneda}}</td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          </section>
        </div>

        <div class="section-grid">
          <section class="section-card">
            <div class="section-head">
              <div>
                <h2>Composição das coberturas</h2>
                <p>Exemplo visual de como a mesma informação pode ser exibida em uma leitura mais analítica.</p>
              </div>
            </div>
            <div class="chart-wrap">
              <div class="chart-box">
                <canvas id="coverageChart"></canvas>
              </div>
              <div class="legend" id="coverageLegend">
                {{#each coberturas}}
                  <div class="legend-item">
                    <div class="legend-left">
                      <span class="legend-dot" data-legend-color></span>
                      <span class="legend-label">{{this.titulo}}</span>
                    </div>
                    <span class="legend-value">{{formatCurrency this.monto ../poliza.moneda}}</span>
                  </div>
                {{/each}}
              </div>
            </div>
          </section>

          <section class="section-card">
            <div class="section-head">
              <div>
                <h2>Detalhe das proteções</h2>
                <p>Formato em lista executiva com valor e explicação resumida.</p>
              </div>
            </div>
            <div class="coverage-list">
              {{#each coberturas}}
                <article class="coverage-item">
                  <strong>
                    <span>{{this.titulo}}</span>
                    <span class="money">{{formatCurrency this.monto ../poliza.moneda}}</span>
                  </strong>
                  <p>{{this.detalle}}</p>
                </article>
              {{/each}}
            </div>
          </section>
        </div>

        <div class="section-grid">
          <section class="section-card">
            <div class="section-head">
              <div>
                <h2>Veículo segurado</h2>
                <p>Resumo principal do bem protegido nesta apólice.</p>
              </div>
            </div>
            <div class="quick-list">
              <div class="quick-item"><label>Marca / Modelo</label><strong>{{default presentation.vehicleTitle vehiculo.modelo}}</strong></div>
              <div class="quick-item"><label>Ano</label><span>{{vehiculo.anio}}</span></div>
              <div class="quick-item"><label>Placa</label><span>{{vehiculo.patente}}</span></div>
              <div class="quick-item"><label>Combustível</label><span>{{vehiculo.combustible}}</span></div>
              <div class="quick-item"><label>Uso</label><span>{{vehiculo.uso}}</span></div>
            </div>
          </section>

          <section class="section-card" id="atendimento">
            <div class="section-head">
              <div>
                <h2>Atendimento e localização</h2>
                <p>Contato comercial e endereço do segurado no mesmo painel.</p>
              </div>
            </div>
            <div class="address-card">
              <label>Endereço</label>
              <strong>{{residencia.direccion}}</strong>
            </div>
            <iframe class="map" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="{{default presentation.mapUrl (concat "https://www.google.com/maps?q=" presentation.encodedAddress "&output=embed")}}"></iframe>
            <div style="height:14px"></div>
            <div class="quick-list">
              <div class="quick-item"><label>Corretora</label><strong>{{corredor.nombre}}</strong></div>
              <div class="quick-item"><label>Telefone</label><span>{{corredor.telefono}}</span></div>
              <div class="quick-item"><label>E-mail</label><span>{{corredor.email}}</span></div>
              <div class="quick-item"><label>Canal 24h</label><span>{{default presentation.primaryChannel "4004 7678"}}</span></div>
            </div>
          </section>
        </div>
      </main>
    </div>
  </div>

  <script id="coverageChartPayload" type="application/json">
    {
      "labels": [{{#each coberturas}}{{#unless @first}},{{/unless}}"{{this.titulo}}"{{/each}}],
      "values": [{{#each coberturas}}{{#unless @first}},{{/unless}}{{default this.monto 0}}{{/each}}]
    }
  </script>
  <script>
    const links = document.querySelectorAll('.nav a');
    const sections = document.querySelectorAll('[id]');
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          links.forEach((link) => {
            link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
          });
        }
      });
    }, { rootMargin: '-30% 0px -55% 0px', threshold: 0.08 });

    sections.forEach((section) => {
      if (section.id) io.observe(section);
    });

    const palette = ['#1e5eff','#4f8bff','#7bb0ff','#9cc5ff','#bdd9ff','#d8e8ff'];
    const chartPayload = JSON.parse(document.getElementById('coverageChartPayload').textContent);
    const legendDots = document.querySelectorAll('[data-legend-color]');
    legendDots.forEach((dot, index) => {
      dot.style.background = palette[index % palette.length];
    });

    const ctx = document.getElementById('coverageChart').getContext('2d');
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels: chartPayload.labels,
        datasets: [{
          data: chartPayload.values,
          backgroundColor: chartPayload.values.map((_, i) => palette[i % palette.length]),
          borderColor: '#ffffff',
          borderWidth: 4,
          hoverOffset: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '58%',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) => `${context.label}: ${new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(context.raw || 0)}`
            }
          }
        }
      }
    });
  </script>
</body>
</html>
