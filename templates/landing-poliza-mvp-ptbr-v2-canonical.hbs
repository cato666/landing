<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{default branding.empresa "Porto Seguro"}} - {{default poliza.numero "Apólice"}}</title>
  <style>
    body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:#f4f8ff;color:#172338}
    .container{max-width:1040px;margin:0 auto;padding:24px}
    .header{background:#ffffff;border:1px solid #d9e4f4;border-radius:24px;padding:24px;box-shadow:0 18px 36px rgba(22,36,63,.08)}
    .header h1{margin:0;font-size:28px;color:#1034a6}
    .header p{margin:8px 0 0;color:#5f6f8b}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px}
    .card{background:#ffffff;border:1px solid #e4ecf8;border-radius:20px;padding:20px}
    .card h2{margin:0 0 14px;font-size:20px;color:#10294b}
    .item{margin-bottom:14px}
    .item label{display:block;font-size:12px;color:#728096;text-transform:uppercase;margin-bottom:6px}
    .item strong, .item span{font-size:15px;color:#16243f}
    .pill-list{display:flex;flex-wrap:wrap;gap:10px}
    .pill{background:#eef3ff;color:#2f6df6;padding:10px 14px;border-radius:999px;font-weight:700;font-size:14px}
    table{width:100%;border-collapse:collapse;margin-top:12px}
    th,td{text-align:left;padding:12px 10px;border-bottom:1px solid #e2eaf4;font-size:14px}
    th{color:#62738b;text-transform:uppercase;font-size:12px}
    .list-item{margin-bottom:12px}
    .footer{margin-top:24px;padding:20px;background:#f7faff;border:1px solid #dbe8ff;border-radius:18px}
    .footer strong{display:block;font-size:15px;color:#10294b;margin-bottom:6px}
    @media(max-width:860px){.row{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{default branding.heroTitle (concat "Olá, " cliente.nome)}}</h1>
      <p>{{default branding.heroDescription "Veja os principais detalhes da sua apólice de forma clara e organizada."}}</p>
      <div class="pill-list" style="margin-top:18px">
        <span class="pill">Apólice {{default poliza.numero "-"}}</span>
        <span class="pill">{{default poliza.estado "Status não disponível"}}</span>
        <span class="pill">{{formatCurrency poliza.primaTotal poliza.moneda}}</span>
      </div>
    </div>

    <div class="row">
      <section class="card">
        <h2>Dados do cliente</h2>
        <div class="item"><label>Nome</label><strong>{{default cliente.nome "-"}}</strong></div>
        <div class="item"><label>Documento</label><span>{{default cliente.documento "-"}}</span></div>
        <div class="item"><label>Telefone</label><span>{{default cliente.telefone "-"}}</span></div>
        <div class="item"><label>E-mail</label><span>{{default cliente.email "-"}}</span></div>
      </section>
      <section class="card">
        <h2>Dados da apólice</h2>
        <div class="item"><label>Período</label><span>{{formatDateBR poliza.vigenciaDesde}} a {{formatDateBR poliza.vigenciaHasta}}</span></div>
        <div class="item"><label>Franquia</label><span>{{formatCurrency poliza.franquia poliza.moneda}}</span></div>
        <div class="item"><label>Prêmio total</label><strong>{{formatCurrency poliza.primaTotal poliza.moneda}}</strong></div>
      </section>
    </div>

    <div class="row" style="margin-top:14px">
      <section class="card">
        <h2>Veículo</h2>
        <div class="item"><label>Marca / Modelo</label><strong>{{default vehiculo.marca ""}} {{default vehiculo.modelo ""}}</strong></div>
        <div class="item"><label>Ano</label><span>{{default vehiculo.anio "-"}}</span></div>
        <div class="item"><label>Placa</label><span>{{default vehiculo.patente "-"}}</span></div>
        <div class="item"><label>Combustível</label><span>{{default vehiculo.combustible "-"}}</span></div>
        <div class="item"><label>Uso</label><span>{{default vehiculo.uso "-"}}</span></div>
      </section>
      <section class="card">
        <h2>Contatos</h2>
        <div class="item"><label>Corretora</label><strong>{{default corredor.nombre "-"}}</strong></div>
        <div class="item"><label>Telefone</label><span>{{default corredor.telefono "-"}}</span></div>
        <div class="item"><label>E-mail</label><span>{{default corredor.email "-"}}</span></div>
        <div class="item"><label>Endereço</label><span>{{default residencia.direccion "-"}}</span></div>
      </section>
    </div>

    <div class="row" style="margin-top:14px">
      <section class="card" style="grid-column:1 / -1">
        <h2>Benefícios</h2>
        <div class="pill-list">
          {{#each beneficios}}
            <span class="pill">{{default this.titulo "Benefício"}}</span>
          {{/each}}
          {{#unless beneficios.length}}
            <span>Nenhum benefício disponível</span>
          {{/unless}}
        </div>
      </section>
    </div>

    <div class="row" style="margin-top:14px">
      <section class="card" style="grid-column:1 / -1">
        <h2>Coberturas</h2>
        {{#each coberturas}}
          <div class="list-item">
            <strong>{{default this.titulo "Cobertura"}}</strong>
            <p>{{default this.detalle "Sem detalhe."}}</p>
            <p style="font-weight:700;color:#0f5fbf">{{formatCurrency this.monto ../poliza.moneda}}</p>
          </div>
        {{/each}}
      </section>
    </div>

    <div class="row" style="margin-top:14px">
      <section class="card" style="grid-column:1 / -1">
        <h2>Parcelas</h2>
        <table>
          <thead>
            <tr><th>Parcela</th><th>Vencimento</th><th>Valor</th></tr>
          </thead>
          <tbody>
            {{#each pagos.cuotas}}
              <tr>
                <td>{{default this.numero "-"}}</td>
                <td>{{formatDateBR this.vencimiento}}</td>
                <td>{{formatCurrency this.valor ../poliza.moneda}}</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </section>
    </div>

    <div class="footer">
      <strong>Observações</strong>
      <p>Aproveite a sua apólice e entre em contato com sua corretora para dúvidas adicionais.</p>
    </div>
  </div>
</body>
</html>
